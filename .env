# ─── Database ─────────────────────────────────────────────
# Update this with your PostgreSQL credentials before running
DATABASE_URL=postgresql://rickyk@localhost:5432/cityissues

# ─── JWT ─────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=dev-secret-key-please-change-me-before-production-use

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ─────────────────────────────────────────────────
PROJECT_NAME="Citizen Issue Processing System"
VERSION=1.0.0
DEBUG=true

# ─── Email (disabled by default) ─────────────────────────
MAIL_ENABLED=false
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@cityissues.gov
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ─── File Storage (local by default) ─────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_TIMES=10
RATE_LIMIT_SECONDS=60

# ─── SLA Thresholds (days) ────────────────────────────────
SLA_CRITICAL_DAYS=1
SLA_HIGH_DAYS=3
SLA_MEDIUM_DAYS=7
SLA_LOW_DAYS=14

# ─── Admin Seed ───────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@cityissues.gov
FIRST_ADMIN_PASSWORD=Admin@123456
