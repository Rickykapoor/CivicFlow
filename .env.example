# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cityissues

# ─── JWT ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-256-bit-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ─────────────────────────────────────────────────
PROJECT_NAME="Citizen Issue Processing System"
VERSION=1.0.0
DEBUG=false
ALLOWED_HOSTS=["*"]

# ─── Email (SMTP) ─────────────────────────────────────────
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@cityissues.gov
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_ENABLED=false

# ─── File Storage ─────────────────────────────────────────
# Options: "local" or "s3"
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=cityissues-uploads

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_TIMES=10
RATE_LIMIT_SECONDS=60

# ─── SLA Thresholds (days) ────────────────────────────────
SLA_CRITICAL_DAYS=1
SLA_HIGH_DAYS=3
SLA_MEDIUM_DAYS=7
SLA_LOW_DAYS=14

# ─── Admin Seed ───────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@cityissues.gov
FIRST_ADMIN_PASSWORD=Admin@123456
